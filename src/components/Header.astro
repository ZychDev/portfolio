---
import { site } from "../data/site";

const navItems = [
  { href: "/", label: "Start" },
  { href: "/o-mnie", label: "O mnie" },
  { href: "/projekty", label: "Projekty" },
  { href: "/blog", label: "Blog" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`);
---

<header class="border-b border-line dark:border-line-dark relative z-30">
  <div
    class="mx-auto max-w-3xl px-6 sm:px-8 py-3 flex items-center gap-3 font-mono text-sm"
  >
    <span class="flex gap-1.5 shrink-0" aria-hidden="true">
      <span class="size-2.5 rounded-full bg-acc/70"></span>
      <span class="size-2.5 rounded-full bg-mut/50"></span>
      <span class="size-2.5 rounded-full bg-line dark:bg-line-dark"></span>
    </span>
    <span class="text-mut truncate hidden sm:inline">
      ~/{site.shortName}/portfolio
    </span>
    <span
      id="clock"
      aria-hidden="true"
      class="hidden md:inline font-mono text-mut text-xs tabular-nums ml-2"
      >[--:--:--]</span
    >
    <nav class="ml-auto flex items-center gap-4 sm:gap-6">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "link-underline transition-colors",
              isActive(item.href)
                ? "text-acc"
                : "text-ink dark:text-ink-dark hover:text-acc dark:hover:text-acc",
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <button
        id="theme-toggle"
        type="button"
        aria-label="Przełącz motyw"
        class="text-mut hover:text-acc transition-colors"
      >
        <span class="dark:hidden">●</span>
        <span class="hidden dark:inline">○</span>
      </button>
    </nav>
  </div>
</header>

<script>
  const initToggle = () => {
    const btn = document.getElementById("theme-toggle");
    if (!btn || btn.dataset.bound === "1") return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const isDark = root.classList.toggle("dark");
      try {
        localStorage.setItem("theme", isDark ? "dark" : "light");
      } catch (_) {
        /* ignore */
      }
    });
  };

  const pad = (n: number) => String(n).padStart(2, "0");
  const tick = () => {
    const el = document.getElementById("clock");
    if (!el) return;
    const d = new Date();
    el.textContent = `[${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}]`;
  };
  const startTicker = () => {
    tick();
    const w = window as typeof window & { __clockTimer?: number };
    if (w.__clockTimer) return;
    w.__clockTimer = window.setInterval(tick, 1000);
  };

  initToggle();
  startTicker();
  document.addEventListener("astro:after-swap", () => {
    initToggle();
    tick();
  });
</script>
