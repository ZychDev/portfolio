---
import Base from "../layouts/Base.astro";
import AsciiDivider from "../components/AsciiDivider.astro";
import { site } from "../data/site";
import { projects } from "../data/projects";

const selected = projects.slice(0, 3);
---

<Base>
  <section class="reveal">
    <p class="font-mono text-acc text-sm">
      <span class="text-mut">$</span> whoami
    </p>
    <h1
      class="font-display text-6xl sm:text-8xl mt-4 leading-[0.95] tracking-tight"
    >
      <span class="glitch" data-text={site.author}>{site.author}</span><span
        class="cursor text-acc"></span>
    </h1>
    <p class="font-mono text-mut mt-6">
      programista &middot; projekty &middot; notatki
    </p>
    <p class="mt-8 max-w-prose leading-relaxed text-lg">
      Cześć. Buduję strony i drobne narzędzia w wolnym czasie, najczęściej
      w TypeScripcie. Tu wrzucam to, co skończę — projekty, notatki
      i myśli z drogi.
    </p>
    <div class="mt-10 flex gap-6 font-mono text-sm">
      <a class="link-underline text-acc" href="/projekty">→ projekty</a>
      <a class="link-underline text-acc" href="/blog">→ blog</a>
    </div>
  </section>

  <AsciiDivider />

  <section class="reveal">
    <h2 class="font-mono text-mut uppercase tracking-[0.25em] text-xs">
      &gt; selected work
    </h2>
    <ul
      class="mt-6 divide-y divide-line dark:divide-line-dark border-y border-line dark:border-line-dark"
    >
      {
        selected.map((p) => (
          <li class="reveal">
            <a
              href={`/projekty#${p.id}`}
              class="group grid grid-cols-[2.5rem_1fr_auto_1.5rem] sm:grid-cols-[3rem_1fr_auto_2rem] items-baseline gap-3 py-5 px-2 hover:bg-acc/5 transition-colors"
            >
              <span class="font-mono text-acc text-sm">{p.num}</span>
              <span class="min-w-0">
                <span class="font-mono text-base sm:text-lg block">
                  {p.title}
                </span>
                <span class="block text-sm text-mut mt-1 line-clamp-2">
                  {p.description}
                </span>
              </span>
              <span class="font-mono text-mut text-sm tabular-nums">
                {p.year}
              </span>
              <span class="font-mono text-acc transition-transform group-hover:translate-x-1">
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>
    <p class="mt-6 font-mono text-sm">
      <a class="link-underline text-acc" href="/projekty">
        <span class="text-mut">$</span> ls -la ~/projects
      </a>
    </p>
  </section>
</Base>
