---
import Base from "../layouts/Base.astro";
import { projects } from "../data/projects";
---

<Base title="Projekty" description="Lista projektów.">
  <section class="reveal">
    <p class="font-mono text-acc text-sm">// projekty</p>
    <h1 class="font-mono text-3xl sm:text-4xl mt-3">ls -la ~/projects/</h1>
    <p class="mt-4 text-mut max-w-prose">
      To co zbudowałem — projekty własne, uczelniane, eksperymenty.
    </p>
  </section>

  <section class="mt-12">
    <ul
      class="divide-y divide-line dark:divide-line-dark border-y border-line dark:border-line-dark"
    >
      {
        projects.map((p) => (
          <li id={p.id} class="reveal group scroll-mt-24">
            <div class="py-6 px-2 hover:bg-acc/5 transition-colors">
              <div class="grid grid-cols-[2.5rem_1fr_auto] sm:grid-cols-[3rem_1fr_auto] gap-3 items-baseline">
                <span class="font-mono text-acc">{p.num}</span>
                <div class="min-w-0">
                  <h3 class="font-mono text-lg sm:text-xl">{p.title}</h3>
                  <p class="text-mut mt-2 leading-relaxed">{p.description}</p>
                  <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs text-mut">
                    {p.tech.map((t) => (
                      <li>#{t}</li>
                    ))}
                  </ul>
                  {(p.url || p.repo) && (
                    <div class="mt-4 flex gap-5 font-mono text-sm">
                      {p.url && (
                        <a
                          class="link-underline text-acc"
                          href={p.url}
                          rel="noreferrer"
                          target="_blank"
                        >
                          → live
                        </a>
                      )}
                      {p.repo && (
                        <a
                          class="link-underline text-acc"
                          href={p.repo}
                          rel="noreferrer"
                          target="_blank"
                        >
                          → repo
                        </a>
                      )}
                    </div>
                  )}
                </div>
                <span class="font-mono text-mut text-sm tabular-nums">
                  {p.year}
                </span>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
