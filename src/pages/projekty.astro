---
import Base from "../layouts/Base.astro";
import { projects } from "../data/projects";
---

<Base title="Projekty" description="Lista projektów.">
  <section class="reveal">
    <p class="font-mono text-acc text-sm glow-soft">
      <span class="text-mut">$</span> ls -la ~/projects/
    </p>
    <h1 class="font-mono text-3xl sm:text-4xl mt-3 text-ink glow">
      <span class="glitch auto" data-text="~/projects/">~/projects/</span>
    </h1>
    <p class="mt-4 text-mut max-w-prose">
      To co zbudowałem — projekty własne, uczelniane, eksperymenty.
    </p>
  </section>

  <section class="mt-12">
    <ul
      class="divide-y divide-line border-y border-line"
    >
      {
        projects.map((p) => (
          <li
            id={p.id}
            class="row-glitch reveal group scroll-mt-24"
          >
            <div class="py-6 px-2 hover:bg-acc/10 transition-colors">
              <div class="grid grid-cols-[2.5rem_1fr_auto] sm:grid-cols-[3rem_1fr_auto] gap-3 items-baseline">
                <span class="num-glitch font-mono text-acc glow-soft" data-text={p.num}>
                  {p.num}
                </span>
                <div class="min-w-0">
                  <h3 class="font-mono text-lg sm:text-xl text-ink">
                    {p.title}
                  </h3>
                  <p class="text-mut mt-2 leading-relaxed">{p.description}</p>
                  <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs text-mut">
                    {p.tech.map((t) => (
                      <li>#{t}</li>
                    ))}
                  </ul>
                  {(p.url || p.repo) && (
                    <div class="mt-4 flex gap-5 font-mono text-sm">
                      {p.url && (
                        <a
                          class="link-underline text-acc glow-soft"
                          href={p.url}
                          rel="noreferrer"
                          target="_blank"
                        >
                          → live
                        </a>
                      )}
                      {p.repo && (
                        <a
                          class="link-underline text-acc glow-soft"
                          href={p.repo}
                          rel="noreferrer"
                          target="_blank"
                        >
                          → repo
                        </a>
                      )}
                    </div>
                  )}
                </div>
                <span class="font-mono text-mut text-sm tabular-nums">
                  {p.year}
                </span>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
