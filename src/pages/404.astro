---
import Base from "../layouts/Base.astro";
---

<Base title="404 — nie znaleziono">
  <section class="text-center py-20 reveal">
    <p class="font-mono text-acc text-sm">
      <span class="text-mut">$</span> cat /var/www/{Astro.url.pathname}
    </p>
    <h1
      class="font-display text-8xl sm:text-[10rem] mt-6 leading-none tracking-tight"
    >
      <span class="glitch" data-text="404">404</span><span
        class="cursor text-acc"></span>
    </h1>
    <p class="mt-6 font-mono text-mut">
      cat: tej strony nie ma w systemie plików
    </p>
    <p class="mt-2 font-mono text-mut text-xs">errno = -2 (ENOENT)</p>
    <a
      href="/"
      class="mt-10 inline-block font-mono text-acc link-underline"
    >
      ← cd ~
    </a>
  </section>
</Base>
