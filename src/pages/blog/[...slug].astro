---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const wordCount = (post.body ?? "").split(/\s+/).filter(Boolean).length;
const readMin = Math.max(1, Math.round(wordCount / 200));

const fmt = (d: Date) =>
  d.toLocaleDateString("pl-PL", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

<Base
  title={post.data.title}
  description={post.data.description}
  type="article"
>
  <article class="reveal">
    <p class="font-mono text-acc text-sm">// blog/{post.id}</p>
    <h1
      class="font-mono text-3xl sm:text-4xl mt-3 leading-tight tracking-tight"
    >
      {post.data.title}
    </h1>
    <p class="mt-4 font-mono text-mut text-sm">
      {fmt(post.data.pubDate)} &middot; {readMin} min czytania
      {
        post.data.updatedDate && (
          <>
            {" "}
            &middot; edytowane {fmt(post.data.updatedDate)}
          </>
        )
      }
    </p>
    {
      post.data.tags.length > 0 && (
        <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 font-mono text-xs text-mut">
          {post.data.tags.map((t) => (
            <li>#{t}</li>
          ))}
        </ul>
      )
    }
    <div class="prose-body mt-10 leading-relaxed text-lg">
      <Content />
    </div>
    <div class="mt-16 font-mono text-sm">
      <a class="link-underline text-acc" href="/blog">← powrót do listy</a>
    </div>
  </article>
</Base>

<style is:global>
  .prose-body h2 {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .prose-body h3 {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    font-size: 1.2rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose-body p {
    margin-block: 1.1rem;
  }
  .prose-body ul {
    list-style: disc;
    padding-left: 1.5rem;
    margin-block: 1rem;
  }
  .prose-body ol {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-block: 1rem;
  }
  .prose-body a {
    color: var(--color-acc);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-body code {
    font-family: "IBM Plex Mono", ui-monospace, monospace;
    background: rgba(181, 83, 42, 0.08);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .prose-body pre {
    background: rgba(43, 42, 38, 0.04);
    padding: 1rem;
    overflow-x: auto;
    border: 1px solid var(--color-line);
    margin-block: 1.25rem;
    font-size: 0.9rem;
  }
  :root.dark .prose-body pre {
    background: rgba(207, 232, 192, 0.04);
    border-color: var(--color-line-dark);
  }
  .prose-body pre code {
    background: transparent;
    padding: 0;
  }
  .prose-body blockquote {
    border-left: 2px solid var(--color-acc);
    padding-left: 1rem;
    color: var(--color-mut);
    margin-block: 1.25rem;
    font-style: italic;
  }
  .prose-body hr {
    border: 0;
    border-top: 1px solid var(--color-line);
    margin-block: 2rem;
  }
  :root.dark .prose-body hr {
    border-color: var(--color-line-dark);
  }
</style>
