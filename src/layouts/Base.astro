---
import "../styles/global.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
import "@fontsource/ibm-plex-mono/700.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/vt323/400.css";

import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEO from "../components/SEO.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const { title, description, image, type } = Astro.props;

const bootLines = [
  "$ ./boot.sh",
  "[ OK ] mounting /content",
  "[ OK ] loading fonts: IBM Plex Mono, Inter, VT323",
  "[ OK ] starting portfolio.service",
  "[ OK ] ready.",
];
---

<!doctype html>
<html lang="pl" class="dark font-sans antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} image={image} type={type} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Blog"
      href="/rss.xml"
    />
    <script is:inline>
      try {
        document.documentElement.classList.add("dark");
        if (sessionStorage.getItem("booted")) {
          document.documentElement.dataset.booted = "1";
        }
      } catch (_) {
        /* ignore */
      }
    </script>
    <ClientRouter />
  </head>
  <body
    class="bg-bg-dark text-ink-dark min-h-screen flex flex-col"
  >
    <div id="boot" aria-hidden="true">
      {
        bootLines.map((line, i) => (
          <span class="boot-line" style={`animation-delay: ${i * 130}ms`}>
            {line.startsWith("[ OK ]") ? (
              <>
                <span class="text-acc-dark">[ OK ]</span>
                {line.slice(6)}
              </>
            ) : line.startsWith("$") ? (
              <>
                <span class="text-acc-dark">$</span>
                {line.slice(1)}
              </>
            ) : (
              line
            )}
          </span>
        ))
      }
    </div>

    <div id="scanline" aria-hidden="true"></div>
    <div id="screen-tear" aria-hidden="true"></div>

    <noscript>
      <style>
        #boot { display: none !important; }
        #screen-tear { display: none !important; }
        .reveal { opacity: 1 !important; transform: none !important; }
      </style>
    </noscript>

    <Header />
    <main
      class="flex-1 mx-auto w-full max-w-3xl px-6 sm:px-8 py-12 sm:py-16"
    >
      <slot />
    </main>
    <Footer />

    <script>
      type RevealEl = HTMLElement;

      const markBooted = () => {
        document.documentElement.dataset.booted = "1";
        try {
          sessionStorage.setItem("booted", "1");
        } catch (_) {
          /* ignore */
        }
      };

      const initBoot = () => {
        const boot = document.getElementById("boot");
        if (!boot) return;
        const reduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        const alreadyBooted = document.documentElement.dataset.booted === "1";
        if (alreadyBooted || reduced) {
          boot.remove();
          markBooted();
          return;
        }
        const total = 5 * 130 + 380;
        window.setTimeout(() => {
          boot.classList.add("fade-out");
          window.setTimeout(() => {
            boot.remove();
            markBooted();
          }, 380);
        }, total);
      };

      const initReveal = () => {
        const els = document.querySelectorAll<RevealEl>(".reveal");
        const reduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (!("IntersectionObserver" in window) || reduced) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
        );
        els.forEach((el) => io.observe(el));
      };

      const fireTear = () => {
        const tear = document.getElementById("screen-tear");
        if (!tear) return;
        tear.classList.remove("fire");
        // restart animation
        void tear.offsetWidth;
        tear.classList.add("fire");
        window.setTimeout(() => tear.classList.remove("fire"), 360);
      };

      const fireGlitch = (el: Element) => {
        el.classList.remove("glitch-fire");
        void (el as HTMLElement).offsetWidth;
        el.classList.add("glitch-fire");
        const dur = 220 + Math.floor(Math.random() * 320);
        window.setTimeout(() => el.classList.remove("glitch-fire"), dur);
      };

      const startGlitchLoop = () => {
        const reduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (reduced) return;
        const w = window as typeof window & { __glitchTimer?: number };
        if (w.__glitchTimer) window.clearInterval(w.__glitchTimer);
        w.__glitchTimer = window.setInterval(() => {
          if (Math.random() < 0.42) {
            const targets = document.querySelectorAll(".glitch.auto");
            targets.forEach((el) => {
              if (Math.random() < 0.7) fireGlitch(el);
            });
            if (Math.random() < 0.35) fireTear();
          }
        }, 3800);
      };

      const initPage = () => {
        initBoot();
        initReveal();
        startGlitchLoop();
      };

      document.addEventListener("astro:page-load", initPage);
    </script>
  </body>
</html>
